{
  "_page": "roderick",
  "_loaded_by": "/public/js/roderick.js",
  "_uses_global": "window.Interstellar (state, position, layout, quadTree)",
  "_session": "V5 Session 3 — thin header, sticky player, sidebar on click",

  "preloader": { "enabled": false },

  "layout": {
    "regions": {
      "header":   { "ratio": 0.06 },
      "main":     { "ratio": 0.88 },
      "controls": { "ratio": 0.06 }
    },
    "mainSplit": {
      "_comment": "Desktop/Tablet only — sidebar appears on album click",
      "left":  { "ratio": 0.72 },
      "right": { "ratio": 0.28, "minPx": 340 }
    },
    "mobile": {
      "albumsRegion": { "width": "100%", "overflow": "auto" },
      "infoRegion": { "display": "none" }
    }
  },

  "positions": {
    "_comment": "Desktop: thin horizontal bar — logo | artist svg | spacer | nav",

    "brandLogo": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.01,
      "anchor": "middle-left"
    },

    "artistName": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.16,
      "anchor": "middle-left"
    },

    "topNav": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.96,
      "anchor": "middle-right"
    }
  },

  "positionBreakpoints": {
    "mobile": {
      "maxWidth": 767,
      "positions": {
        "brandLogo": {
          "system": "cartesian",
          "top": 0.15,
          "left": 0.50,
          "anchor": "top-center"
        },
        "topNav": {
          "system": "cartesian",
          "top": 0.50,
          "left": 0.50,
          "anchor": "middle-center"
        },
        "artistName": {
          "system": "cartesian",
          "top": 0.85,
          "left": 0.50,
          "anchor": "bottom-center"
        }
      }
    },

    "tablet": {
      "minWidth": 768, "maxWidth": 1023,
      "positions": {
        "topNav": {
          "system": "cartesian",
          "left": 0.95
        },
        "artistName": {
          "system": "cartesian",
          "left": 0.18
        }
      }
    },

    "desktop": {
      "minWidth": 1024,
      "positions": {
        "topNav": {
          "system": "cartesian",
          "left": 0.96
        }
      }
    }
  },

  "quadTree": {
    "albumGrid": {
      "enabled": true,
      "tile":   { "aspect": 1.0 },
      "gap":    { "px": 16 },
      "columns": {
        "mobile":  { "max": 2 },
        "tablet":  { "max": 4 },
        "desktop": { "max": 6 },
        "ultra":   { "max": 7 }
      },
      "minTilePx": 140,
      "maxTilePx": 280
    }
  },

  "data": {
    "albumsSource": "/api/albums",
    "preloadAlbumArt": true
  },

  "themeRefs": {
    "paintKey": "default",
    "componentPaint": {
      "header": "header",
      "nav": "nav",
      "main": "main",
      "sidebar": "sidebar",
      "player": "player",
      "footer": "footer",
      "badges": "badges"
    }
  },

  "typography": {
    "header": {
      "logo": { "width": "180px" },
      "nav": { "fontSize": "14px", "gap": "20px" }
    },
    "mobile": {
      "header": {
        "logo": { "width": "130px" },
        "nav": { "fontSize": "12px", "gap": "10px" }
      }
    }
  }
}