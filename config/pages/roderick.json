{
  "_page": "roderick",
  "_loaded_by": "/public/js/roderick.js",
  "_uses_global": "window.Interstellar (state, position, layout, quadTree)",
  "_session": "V5 Session 3 — RODUX-driven layout, no inline CSS",

  "preloader": { "enabled": false },

  "layout": {
    "regions": {
      "header":   { "ratio": 0.06, "_note": "thin fixed bar" },
      "main":     { "ratio": 0.88 },
      "controls": { "ratio": 0.06, "_note": "player bar, always visible" }
    },
    "mainSplit": {
      "_comment": "Desktop/Tablet: grid + sidebar when album selected",
      "left":  { "ratio": 0.74 },
      "right": { "ratio": 0.26, "minPx": 320 }
    },
    "mobile": {
      "_comment": "Mobile: sidebar overlays, grid is full width",
      "albumsRegion": { "width": "100%", "overflow": "auto" },
      "infoRegion": { "display": "none", "_note": "CSS overlay via .open class" }
    }
  },

  "positions": {
    "_comment": "Desktop: horizontal header — logo | artist | nav",

    "brandLogo": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.01,
      "anchor": "middle-left"
    },

    "artistName": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.16,
      "anchor": "middle-left"
    },

    "topNav": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.98,
      "anchor": "middle-right"
    }
  },

  "positionBreakpoints": {
    "mobile": {
      "maxWidth": 767,
      "positions": {
        "brandLogo": {
          "system": "cartesian",
          "top": 0.50,
          "left": 0.02,
          "anchor": "middle-left"
        },
        "topNav": {
          "system": "cartesian",
          "top": 0.50,
          "left": 0.98,
          "anchor": "middle-right"
        },
        "artistName": {
          "system": "cartesian",
          "top": 0.50,
          "left": 0.30,
          "anchor": "middle-left",
          "styles": { "fontSize": "14px" }
        }
      }
    },

    "tablet": {
      "minWidth": 768, "maxWidth": 1023,
      "positions": {
        "artistName": {
          "left": 0.18
        },
        "topNav": {
          "left": 0.97
        }
      }
    },

    "desktop": {
      "minWidth": 1024,
      "positions": {
        "topNav": {
          "left": 0.98
        }
      }
    }
  },

  "quadTree": {
    "albumGrid": {
      "enabled": true,
      "tile":   { "aspect": 1.0 },
      "gap":    { "px": 16 },
      "columns": {
        "mobile":  { "max": 2 },
        "tablet":  { "max": 4 },
        "desktop": { "max": 7 },
        "ultra":   { "max": 8 }
      },
      "minTilePx": 120,
      "maxTilePx": 260
    }
  },

  "data": {
    "albumsSource": "/api/albums",
    "preloadAlbumArt": true
  },

  "themeRefs": {
    "paintKey": "default",
    "componentPaint": {
      "header": "header",
      "nav": "nav",
      "main": "main",
      "sidebar": "sidebar",
      "player": "player",
      "footer": "footer",
      "badges": "badges"
    }
  }
}