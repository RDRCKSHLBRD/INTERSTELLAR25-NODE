{
  "_page": "roderick",
  "_version": "5.3",
  "_loaded_by": "/public/js/roderick.js",
  "_uses_global": "window.Interstellar (state, position, layout, quadTree)",

  "preloader": { "enabled": false },

  "layout": {
    "regions": {
      "header":   { "ratio": 0.05, "sticky": true },
      "main":     { "ratio": 0.87, "overflow": "auto" },
      "controls": { "ratio": 0.08, "sticky": "bottom" }
    },
    "mainSplit": {
      "_comment": "Desktop/Tablet — sidebar appears on album click",
      "left":  { "ratio": 0.72 },
      "right": { "ratio": 0.28, "minPx": 320, "hidden": true }
    },
    "mobile": {
      "albumsRegion": { "width": "100%", "overflow": "auto" },
      "infoRegion": { "display": "none", "overlay": true }
    }
  },

  "positions": {
    "brandLogo": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.01,
      "anchor": "middle-left"
    },
    "artistName": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.16,
      "anchor": "middle-left"
    },
    "topNav": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.98,
      "anchor": "middle-right"
    },
    "playerControls": {
      "system": "cartesian",
      "top": 0.50,
      "left": 0.50,
      "anchor": "center",
      "styles": { "width": "100%" }
    }
  },

  "positionBreakpoints": {
    "mobile": {
      "maxWidth": 767,
      "positions": {
        "brandLogo": {
          "system": "cartesian",
          "top": 0.50,
          "left": 0.02,
          "anchor": "middle-left"
        },
        "artistName": {
          "system": "cartesian",
          "top": 0.50,
          "left": 0.30,
          "anchor": "middle-left"
        },
        "topNav": {
          "system": "cartesian",
          "top": 0.50,
          "left": 0.98,
          "anchor": "middle-right"
        }
      }
    },
    "tablet": {
      "minWidth": 768, "maxWidth": 1023,
      "positions": {
        "topNav": {
          "system": "cartesian",
          "left": 0.97
        }
      }
    },
    "desktop": {
      "minWidth": 1024,
      "positions": {
        "topNav": {
          "system": "cartesian",
          "left": 0.98
        }
      }
    }
  },

  "quadTree": {
    "albumGrid": {
      "enabled": true,
      "tile":    { "aspect": 1.0 },
      "gap":     { "px": 12 },
      "margin":  { "pct": 0.015 },
      "columns": {
        "mobile":  { "max": 2 },
        "tablet":  { "max": 4 },
        "desktop": { "max": 6 },
        "ultra":   { "max": 8 }
      },
      "minTilePx": 120,
      "maxTilePx": 240
    }
  },

  "sidebar": {
    "_comment": "Album detail sidebar — driven by roderick.js, paint from paint.json",
    "typography": {
      "title":       { "fontSize": "17px", "fontWeight": "600" },
      "description": { "fontSize": "12.5px", "fontWeight": "200", "lineHeight": "1.55" },
      "credit":      { "fontSize": "11.5px", "fontWeight": "200" },
      "meta":        { "fontSize": "11px" },
      "track":       { "fontSize": "12.5px", "fontWeight": "200" },
      "duration":    { "fontSize": "11.5px", "fontFamily": "monospace" },
      "section":     { "fontSize": "10px", "fontWeight": "600", "letterSpacing": "1px", "textTransform": "uppercase" }
    },
    "cover": { "maxWidth": "260px" }
  },

  "player": {
    "_comment": "Custom player component — no user-agent controls",
    "layout": "horizontal",
    "buttons": ["prev", "play", "next", "stop", "loop"],
    "showVolume": true,
    "showProgress": true,
    "showTime": true,
    "showAddToCart": true
  },

  "data": {
    "albumsSource": "/api/albums",
    "preloadAlbumArt": true
  },

  "themeRefs": {
    "paintKey": "default",
    "componentPaint": {
      "header": "header",
      "nav": "nav",
      "main": "main",
      "sidebar": "sidebar",
      "player": "player",
      "footer": "footer",
      "badges": "badges"
    }
  },

  "typography": {
    "header": {
      "logo": { "width": "160px" },
      "artistName": { "fontSize": "15px", "fontWeight": "200", "letterSpacing": "0.5px" },
      "nav": { "fontSize": "13px", "gap": "16px" }
    },
    "mobile": {
      "header": {
        "logo": { "width": "100px" },
        "artistName": { "fontSize": "13px" },
        "nav": { "fontSize": "12px", "gap": "10px" }
      }
    }
  }
}