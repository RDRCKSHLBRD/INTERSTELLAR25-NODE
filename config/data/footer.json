{
  "_component": "footer",
  "_version": "6.3.1",
  "_engine": "footerQuadTree.js",
  "_stack": "RODUX: StateJS → RatioEngine → cssJSON → QuadTree → CSS vars",
  "_comment": "Profiles are mathematical constraint sets. Device-aware: touch vs pointer. Desktop resized small ≠ phone.",

  "profiles": [
    {
      "name": "compact-portrait",
      "_comment": "Touch device, portrait, ≤767px. Wireframe layout: title row → transport row → seek+time row → nav row → logo row. Everything stacks full-width.",
      "device": "touch",
      "orientation": "portrait",
      "maxWidth": 767,
      "stacked": true,
      "layout": "stacked",
      "height": "auto",
      "volumeVisible": false,
      "order": { "player": 1, "nav": 2, "logo": 3 },
      "zones": {
        "player": { "minPx": 0 },
        "nav":    { "minPx": 0 },
        "logo":   { "minPx": 0 }
      },
      "vars": {
        "--player-btn-size": "36px",
        "--player-icon-size": "24px",
        "--player-btn-gap": "6px",
        "--player-title-max-w": "100%",
        "--player-title-font": "14px",
        "--player-time-font": "12px",
        "--seek-max-w": "none",
        "--seek-min-w": "40%",
        "--seek-height": "8px",
        "--nav-font": "13px",
        "--nav-padding": "10px 14px",
        "--logo-img-h": "16px",
        "--logo-tag-font": "9px",
        "--logo-padding": "6px 10px",
        "--user-icon-size": "16px",
        "--user-name-font": "10px",
        "--user-cell-padding": "6px 10px",
        "--toggle-font": "11px",
        "--toggle-padding": "6px 16px"
      }
    },
    {
      "name": "two-tier",
