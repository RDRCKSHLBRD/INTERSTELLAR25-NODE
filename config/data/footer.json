{
  "_component": "footer",
  "_version": "7.0.0",
  "_engine": "footerQuadTree.js",
  "_stack": "RODUX: StateJS → RatioEngine → cssJSON → QuadTree → CSS vars",
  "_architecture": "Group-based packing. Five named groups flow L→R, wrap on overflow. Transport pinned left. Action+Logo pinned right. No layout modes — one algorithm.",

  "groups": {
    "transport": {
      "order": 1,
      "pinned": "left",
      "minPx": 140,
      "maxPx": 320,
      "idealPx": 180,
      "priority": 1,
      "internal": {
        "columns": 3,
        "btnSize": "var(--player-btn-size)",
        "btnGap": "var(--player-btn-gap)",
        "padding": "4px 6px"
      }
    },

    "information": {
      "order": 2,
      "pinned": false,
      "minPx": 180,
      "maxPx": 9999,
      "idealPx": 350,
      "greedy": true,
      "priority": 2,
      "internal": {
        "layout": "column",
        "row1": ["title"],
        "row2": ["seek", "time"],
        "row3_pointer_only": ["volume"],
        "titleMaxRatio": 0.6,
        "padding": "4px 12px",
        "gap": "3px"
      }
    },

    "link": {
      "order": 3,
      "pinned": false,
      "minPx": 100,
      "maxPx": 400,
      "idealPx": 180,
      "priority": 3,
      "internal": {
        "layout": "inline",
        "gap": "0",
        "separator": "var(--footer-separator)"
      }
    },

    "action": {
      "order": 4,
      "pinned": "right",
      "minPx": 80,
      "maxPx": 250,
      "idealPx": 140,
      "priority": 4,
      "internal": {
        "layout": "inline",
        "gap": "0",
        "separator": "var(--footer-separator)"
      }
    },

    "logo": {
      "order": 5,
      "pinned": "right",
      "minPx": 80,
      "maxPx": 200,
      "idealPx": 120,
      "priority": 5,
      "internal": {
        "layout": "column",
        "align": "center",
        "padding": "var(--logo-padding)"
      }
    }
  },

  "packing": {
    "groupGap": 0,
    "rowGap": 0
  },

  "device": {
    "touch": { "volumeVisible": false },
    "pointer": { "volumeVisible": true }
  },

  "profiles": {
    "compact": {
      "maxWidth": 767,
      "vars": {
        "--player-btn-size": "30px",
        "--player-icon-size": "20px",
        "--player-btn-gap": "3px",
        "--player-title-font": "13px",
        "--player-time-font": "11px",
        "--seek-height": "6px",
        "--nav-font": "12px",
        "--nav-padding": "8px 10px",
        "--logo-img-h": "18px",
        "--logo-tag-font": "9px",
        "--logo-padding": "4px 10px"
      }
    },
    "standard": {
      "minWidth": 768,
      "maxWidth": 1279,
      "vars": {
        "--player-btn-size": "38px",
        "--player-icon-size": "30px",
        "--player-btn-gap": "4px",
        "--player-title-font": "13px",
        "--player-time-font": "12px",
        "--seek-height": "6px",
        "--nav-font": "13px",
        "--nav-padding": "10px 16px",
        "--logo-img-h": "30px",
        "--logo-tag-font": "10px",
        "--logo-padding": "8px 20px",
        "--vol-track-w": "80px"
      }
    },
    "wide": {
      "minWidth": 1280,
      "vars": {
        "--player-btn-size": "45px",
        "--player-icon-size": "40px",
        "--player-btn-gap": "4px",
        "--player-title-font": "13px",
        "--player-time-font": "12px",
        "--seek-height": "6px",
        "--nav-font": "14px",
        "--nav-padding": "10px 20px",
        "--logo-img-h": "38px",
        "--logo-tag-font": "11px",
        "--logo-padding": "12px 34px 10px",
        "--vol-track-w": "100px"
      }
    }
  },

  "nav": {
    "items": ["playlists", "film", "contact"],
    "separator": "1px solid rgba(43, 127, 140, 0.25)"
  },

  "actions": {
    "items": ["login", "cart"]
  },

  "logo": {
    "tagColor": "#829D9E",
    "tagText": "rdxenv 24/25/26"
  },

  "toggle": {
    "text": "PLAYER I/O",
    "textTransform": "uppercase",
    "letterSpacing": "1.5px"
  }
}