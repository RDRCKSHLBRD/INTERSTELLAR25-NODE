        "--nav-padding": "10px 20px",
        "--logo-img-h": "38px",
        "--logo-padding": "12px 34px 10px",
        "--user-icon-size": "20px",
        "--user-name-font": "11px",
        "--user-logout-font": "9px",
        "--user-cell-padding": "6px 16px"
      }
    },
    {
      "name": "wide",
      "_comment": "Desktop/pointer, ≥1600px. Large monitors.",
      "device": "pointer",
      "minWidth": 1600,
      "stacked": false,
      "layout": "horizontal",
      "height": 75,
      "volumeVisible": true,
      "zones": {
        "player": { "minPx": 400 },
