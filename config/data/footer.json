      "vars": {
        "--player-btn-size": "45px",
        "--player-icon-size": "40px",
        "--player-title-max-w": "600px",
        "--player-title-font": "14px",
        "--seek-max-w": "300px",
        "--vol-track-w": "120px",
        "--nav-font": "14px",
        "--nav-padding": "10px 24px",
        "--logo-img-h": "38px",
        "--logo-padding": "12px 34px 10px"
      }
    }
  ],

  "zones": {
    "_comment": "Default zone constraints. Profiles override these.",
    "player": { "priority": 1, "greedy": true, "minPx": 200 },
    "nav":    { "priority": 2, "shrink": 0, "minPx": 0 },
    "logo":   { "priority": 3, "shrink": 0, "widthPx": 80, "minPx": 60 }
  },

  "nav": {
    "items": ["playlists", "film", "contact", "login", "cart"],
    "separator": "1px solid rgba(43, 127, 140, 0.25)"
  },

  "logo": {
    "tagColor": "#829D9E",
    "tagText": "rdxenv 24/25/26"
  },

  "toggle": {
    "text": "PLAYER I/O",
    "textTransform": "uppercase",
    "letterSpacing": "1.5px"
  },

  "mobile": {
    "_comment": "Legacy compat. Profiles replace this.",
    "stackBreakpoint": 767,
    "layout": "stacked"
  }
}