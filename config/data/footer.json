        "--nav-font": "13px",
        "--nav-padding": "8px 14px",
        "--logo-img-h": "18px",
        "--logo-tag-font": "9px",
        "--logo-padding": "4px 14px",
        "--user-icon-size": "16px",
        "--user-name-font": "10px",
        "--user-logout-font": "8px",
        "--user-cell-padding": "4px 10px",
        "--toggle-font": "11px",
        "--toggle-padding": "4px 14px"
