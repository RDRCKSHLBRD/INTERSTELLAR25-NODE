      "device": "touch",
      "orientation": "landscape",
      "maxWidth": 1023,
      "stacked": false,
      "layout": "two-tier",
      "height": "auto",
      "volumeVisible": false,
      "order": { "player": 1, "nav": 2, "logo": 3 },
      "zones": {
        "player": { "minPx": 0 },
        "nav":    { "minPx": 0 },
        "logo":   { "minPx": 0 }
