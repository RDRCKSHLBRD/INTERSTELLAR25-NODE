        "--player-title-font": "13px",
        "--player-time-font": "12px",
        "--player-time-min-w": "78px",
        "--seek-max-w": "none",
        "--seek-min-w": "120px",
        "--seek-height": "6px",
        "--nav-font": "13px",
        "--nav-padding": "10px 16px",
        "--logo-img-h": "22px",
