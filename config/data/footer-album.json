{
  "_component": "footer-album",
  "_version": "1.0.0",
  "_description": "Compact album player footer. Two columns: left (transport 3x3 + title + seek), right (nav + actions stacked). Palette inherited from album CSS vars.",

  "layout": {
    "columns": 2,
    "left": {
      "contains": ["transport", "info"],
      "transport": {
        "columns": 3,
        "rows": 3,
        "btnSize": 32,
        "btnGap": 2
      },
      "info": {
        "titleBelow": true,
        "seekBelow": true,
        "titleMaxWidth": "100%",
        "seekHeight": 4,
        "timeVisible": true,
        "volumeVisible": false
      }
    },
    "right": {
      "contains": ["nav", "actions"],
      "direction": "column",
      "items": ["downloads", "film", "playlists", "subscribe", "login", "cart"]
    }
  },

  "palette": {
    "inherit": true,
    "bg": "var(--c-bg)",
    "text": "var(--c-text)",
    "accent": "var(--c-accent)",
    "track": "var(--c-track)",
    "separator": "rgba(255, 192, 215, 0.12)"
  }
}